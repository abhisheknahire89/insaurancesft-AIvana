# Client-side environment variables (prefixed with VITE_)
# Set VITE_GEMINI_API_KEY to unblock the client-side startup checks and run local scripts
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Vertex AI MedGemma endpoint URL
# If left empty, Aivana will fall back to the main Gemini model for clinical document auditing
# VITE_MEDGEMMA_ENDPOINT_URL=https://us-central1-aiplatform.googleapis.com/v1/projects/YOUR_PROJECT/locations/us-central1/endpoints/YOUR_ENDPOINT_ID

# Optional: Demo Mode
# If true, uses pre-seeded canned case reviews for Diabetes, Pneumonia, and Appendicitis instead of calling live AI
VITE_DEMO_MODE=false

# Serverless function environment variables (server-side only, NO VITE_ prefix)
# This will be securely configured inside the Vercel Dashboard env settings for production
GEMINI_API_KEY=your-gemini-api-key-here

# ── Cerebras / Qwen endpoint (optional, replaces Gemini for Fairway clinical reasoning) ────────
# Sign up free at https://cloud.cerebras.ai (no credit card required)
# 1. Generate an API key from your Cerebras dashboard
# 2. Copy the exact endpoint URL from their docs (OpenAI-compatible /v1/chat/completions)
# 3. Copy the exact model ID from their model list (do NOT guess — it must match verbatim)
# 4. If endpoint is set but the request fails, Aivana falls back to Gemini silently.
#    Watch console for [PATH: qwen_endpoint] to confirm the endpoint is actually being hit.
# VITE_QWEN_ENDPOINT_URL=https://api.cerebras.ai/v1/chat/completions
# VITE_QWEN_API_KEY=your-cerebras-api-key-here
# VITE_QWEN_MODEL_NAME=qwen-3-32b
# (Local Ollama users: leave VITE_QWEN_API_KEY unset; VITE_QWEN_MODEL_NAME defaults to qwen2.5:7b)
