{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "devCommand": "vite",
  "rewrites": [
    {
      "source": "/api/gemini",
      "destination": "/api/gemini.ts"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/:path*.ts"
    },
    {
      "source": "/api/users/:path*",
      "destination": "/api/users/:path*.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
